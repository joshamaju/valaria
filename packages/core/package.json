{
  "name": "foundryjs",
  "type": "module",
  "version": "0.0.0",
  "description": "The Javascript UI toolbelt",
  "homepage": "https://github.com/joshamaju/kitel",
  "author": "Joshua Amaju <joshsemail4work@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "directory": "packages/core",
    "url": "https://github.com/joshamaju/kitel.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "keywords": [
    "pager",
    "carousel",
    "pagination"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "tsc",
    "docs": "docgen",
    "dev": "tsc --watch",
    "prepublish": "pnpm build",
    "test:others": "vitest run",
    "version": "changeset version",
    "release": "changeset publish",
    "test:browser": "playwright test",
    "test": "pnpm run test:others && pnpm run test:browser"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Pager": {
      "types": "./dist/Pager.d.ts",
      "import": "./dist/Pager.js"
    },
    "./Pagination": {
      "types": "./dist/Pagination.d.ts",
      "import": "./dist/Pagination.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@effect/docgen": "^0.5.2",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.1",
    "@vitest/browser-playwright": "^4.0.15",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
