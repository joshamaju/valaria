{
  "name": "@valaria/virtual-scroll",
  "version": "0.0.1",
  "description": "A direct-child virtual scrolling custom element with logical host DOM semantics",
  "homepage": "https://github.com/joshamaju/valaria",
  "author": "Joshua Amaju <joshsemail4work@gmail.com>",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "directory": "packages/virtual-scroll",
    "url": "https://github.com/joshamaju/valaria.git"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "docs": "docgen",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build",
    "test:others": "vitest run",
    "version": "changeset version",
    "release": "changeset publish",
    "test": "pnpm playwright:install && vitest run",
    "playwright:install": "pnpm exec playwright install",
    "test:browser": "pnpm run playwright:install && vitest run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "keywords": [
    "virtual-scroll",
    "virtualization",
    "scrolling",
    "dom",
    "component",
    "element",
    "custom element",
    "web",
    "javascript",
    "ui"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@effect/docgen": "^0.5.2",
    "@vitest/browser-playwright": "^4.0.15",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}